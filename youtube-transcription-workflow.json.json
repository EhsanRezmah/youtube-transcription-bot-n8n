    {
      "parameters": {
        "jsCode": "const text = items[0].json.text; // گرفتن متن از ورودی\nconst chunkSize = 4000; // اندازه هر چانک (قابل تغییر)\nconst chunks = [];\n\nif (text.length <= chunkSize) {\n    // اگر متن کوتاه بود، همان را برگردان\n    return [{ json: { text: text } }];\n}\n\n// اگر متن طولانی بود، آن را تقسیم کن\nfor (let i = 0; i < text.length; i += chunkSize) {\n    chunks.push({\n        json: {\n            text: text.substring(i, i + chunkSize)\n        }\n    });\n}\n\nreturn chunks;"
      },
